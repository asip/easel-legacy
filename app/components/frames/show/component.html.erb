<div id="frames">
  <br>
  <div class="card bg-base-100 shadow rounded-[20px] ml-2 mr-2">
    <div class="card-body">
      <div class="flex justify-between">
        <div>
          <%# map = helpers.query_map_for_search %>
          <%#= map %>
          <%= link_to helpers.back_to_path do %><i class="bi bi-arrow-left-circle text-accent hover:text-primary"></i><% end %>
        </div>
        <div>
          <% map = Oj.dump(helpers.query_map) %>
          <%= link_to user_path(@frame.user),
                      class: "link link-hover",
                      "data-controller": "queryMap",
                      "data-action": "click->queryMap#setQueryMap",
                      "data-queryMap-q-value": map do %>
            <%= @frame.user.name %>
          <% end %>
        </div>
      </div>
      <div class="flex justify-center mb-2">
        <%= render ::Display::Image::Component.new(model: @frame, original: true, photoswipe: true) %>
      </div>
      <div class="flex justify-center flex-wrap gap-1 mb-2">
        <% if helpers.user_signed_in? && @frame.user_id == helpers.current_user.id %>
        <div class="badge badge-outline badge-accent rounded-full"><%= t("enums.private.#{@frame.private}") %></div>
        <% end %>
        <%= render ::Display::Tags::Component.new(tag_map: @tag_map) %>
      </div>
      <%= render Frames::Profile::Component.new(frame: @frame) %>
      <% if helpers.user_signed_in? && @frame.user_id == helpers.current_user.id %>
      <div class="flex justify-center gap-2">
        <%= link_to "変更", edit_frame_path(@frame), class: "btn btn-outline btn-primary", "data-turbo-prefetch": false %>
        <%# Button trigger modal %>
        <button type="button" class="btn btn-outline btn-secondary" onclick="delete_modal.showModal()">
          削除
        </button>
        <%= link_to "戻る", helpers.back_to_path, class: "btn btn-outline btn-warning" %>
      </div>
      <% end %>
    </div>
  </div>
  <% if helpers.user_signed_in? && @frame.user_id == helpers.current_user.id %>
    <%= render Modal::Frames::Delete::Component.new(path: frame_path(@frame)) %>
  <% end %>
  <%= render Front::Component.new(path: "frame/Comments") %>
</div>
