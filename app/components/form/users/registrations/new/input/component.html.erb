<div class="flex justify-center">
  <table class="table table-bordered table-rounded" data-controller="preview">
    <tbody>
      <tr>
        <td class="w-[11em]">
          アイコン
        </td>
        <td>
          <%= @form.file_field :image, accept: "image/jpg,image/jpeg,image/png,image/webp,image/avif",
                                       multiple: false,
                                       class: "file-input",
                                       "data-action": "change->preview#upload" %>
          <%= render Display::Messages::Component.new(model: @user, attr: :image) %>
        </td>
      </tr>
      <tr>
        <td colspan="2" class="juestify-center hidden" data-preview-target="content">
          <%= render Display::Image::Preview::Component.new(model: @user) %>
        </td>
      </tr>
      <tr>
        <td>
          <label for="user_name">ユーザー名</label>
        </td>
        <td>
          <%= @form.text_field :name, autofocus: true, autocomplete: "username", placeholder: "", class: "input" %>
          <%= render Display::Messages::Component.new(model: @user, attr: :name) %>
        </td>
      </tr>
      <tr>
        <td>
          <label for="user_email"><%= t("activerecord.attributes.user.email") %></label>
        </td>
        <td>
          <%= @form.email_field :email, placeholder: "", autofocus: true, autocomplete: "email",
                                        class: "input" %>
          <%= render Display::Messages::Component.new(model: @user, attr: :email) %>
        </td>
      </tr>
      <tr>
        <td>
          <label for="user_profile"><%= t("activerecord.attributes.user.profile") %></label>
        </td>
        <td class="wrap-break-word">
          <%= @form.text_area :profile, class: "block text-sm border border-gray-300 rounded w-full min-h-12.5 field-sizing-content" %>
        </td>
      </tr>
      <tr>
        <td>
          <label for="user_time_zone"><%= t("activerecord.attributes.user.time_zone") %></label>
        </td>
        <td>
          <% @user.time_zone = Time.zone.name %>
          <%= @form.select :time_zone, TimeZoneUtil.tzinfo_options, {}, class: "select" %>
        </td>
      </tr>
      <tr>
        <td>
          <label for="user_password"><%= t("activerecord.attributes.user.password") %></label>
        </td>
        <td>
          <%= @form.password_field :password, placeholder: "", autocomplete: "new-password",
                                              class: "input" %>
          <%= render Display::Messages::Component.new(model: @user, attr: :password) %>
        </td>
      </tr>
      <tr>
        <td>
          <label for="user_password_confirmation">パスワード(確認)</label>
        </td>
        <td>
          <%= @form.password_field :password_confirmation, placeholder: "", autocomplete: "new-password",
                                                           class: "input" %>
          <%= render Display::Messages::Component.new(model: @user, attr: :password_confirmation) %>
        </td>
      </tr>
    </tbody>
  </table>
</div>
<div class="flex justify-center gap-2 mt-2">
  <%= render Form::Element::Button::Confirm::Component.new(form: @form) %>
  <%= render Form::Element::Link::Back::Component.new(url: @back_to_path) %>
</div>
