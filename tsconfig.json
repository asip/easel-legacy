{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strictFunctionTypes": false,
    "outDir": "./app/assets/builds",
    "types": ["vite/client"],
    "paths": {
      "@": ["./app/frontend"],
      "@/*": ["./app/frontend/*"]
    }
  },
  "include": ["./app/frontend/**/*.ts", "./app/frontend/**/*.vue", "./vite.config.ts"],
  "exclude": ["./node_modules"]
}
