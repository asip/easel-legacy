{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strictFunctionTypes": false,
    "outDir": "./app/assets/builds",
    "paths": {
      "~": ["./app/frontend"],
      "~/*": ["./app/frontend/*"],
      "@voyage/vue": ["./packages/voyage-vue"],
      "@voyage/vue/*": ["./packages/voyage-vue/*"],
      "vanillajs-datepicker": ["./node_modules/vanillajs-datepicker"],
      "vanillajs-datepicker/*": ["./node_modules/vanillajs-datepicker/*"]
    }
  },
  "include": ["./app/frontend/**/*.ts", "./packages/voyage-vue/*+/*.ts", "./app/frontend/**/*.vue", "./vite.config.ts"],
  "exclude": ["./node_modules"]
}
